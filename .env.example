GEMINI_API_KEY=your_gemini_api_key_here
NEWS_API_KEY=your_news_data_io_api_key_here

# Model Selection — change this to swap the LLM powering the agents
# Options:
#   gemma-4-27b-it-gai   → Gemma 4 31B (most capable, via Google AI Studio) [DEFAULT]
#   gemma-4-E4B-it       → Gemma 4 E4B (faster, lightweight)
#   gemini-2.0-flash     → Gemini 2.0 Flash (Gemini API, free tier)
#   gemini-1.5-flash     → Gemini 1.5 Flash (older but stable)
SIGNAL_MODEL=gemma-4-27b-it-gai
